BITS 64
default rel

extern main

section .text
global _start

_start:
    mov ax, 0x23
    mov ds, ax
    mov es, ax

    mov edi, dword [rsp]
    lea rsi, [rsp + 8]
    and rsp, -16
    sub rsp, 8
    call main

    mov edi, eax
    mov eax, 2
    int 0x80

.hang:
    jmp .hang

section .note.GNU-stack noalloc noexec nowrite progbits
